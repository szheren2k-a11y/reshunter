{
  "manifest_version": 3,
  "name": "资源猎手 Resource Hunter",
  "version": "4.0.0",
  "description": "静态扫描网页资源，支持递归下探，批量下载",

  "action": {
    "default_popup": "popup.html",
    "default_title": "资源猎手",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "permissions": [
    "activeTab",
    "tabs",
    "downloads",
    "scripting"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
